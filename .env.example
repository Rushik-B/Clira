# ===== REQUIRED =====

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/clira

# Redis
REDIS_URL=redis://localhost:16379

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail Push Notifications
GMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/clira-email-updates
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# LLM Provider (v1: Gemini only)
GOOGLE_GENERATIVE_AI_API_KEY=

# Feature flags
FEATURE_FLAG_GMAIL_DRAFTS=true

# ===== OPTIONAL =====

# SMS / Twilio (Executive Agent channel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# WhatsApp Cloud API (Executive Agent channel)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v22.0

# Telegram Bot API (Executive Agent channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=true
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_RETRY_MAX_MS=30000

# Long-term memory (Supermemory)
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_TIMEOUT_MS=10000

# Optional runtime tuning
NODE_ENV=development
LOG_LEVEL=info

# Public contact + CTA configuration (safe to expose)
NEXT_PUBLIC_SUPPORT_EMAIL=support@clira.dev
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_CLIRA_TEXT_NUMBER=
NEXT_PUBLIC_WHATSAPP_CTA_URL=
