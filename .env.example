# ===== REQUIRED FOR FIRST SUCCESSFUL SELF-HOST =====

# Docker image to pull for self-host deployments.
CLIRA_IMAGE=ghcr.io/rushik-b/clira:latest

# Database
CLIRA_DB_APP_USER=clira_app
CLIRA_DB_APP_PASSWORD=clira_app
DATABASE_URL=postgresql://clira_app:clira_app@localhost:15432/clira
DIRECT_URL=postgresql://clira_app:clira_app@localhost:15432/clira

# Redis
REDIS_URL=redis://localhost:16379

# Public app URL used by Docker and browser-based auth callbacks.
APP_PUBLIC_URL=http://localhost:13000
NEXTAUTH_URL=http://localhost:13000

# Generated automatically by `npm run selfhost:init`.
NEXTAUTH_SECRET=
CRON_SECRET=
EMAIL_ENCRYPT_SECRET=
EMAIL_ENCRYPT_SALT=

# Gmail OAuth and ingestion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_INGESTION_MODE=pull
GMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/clira-email-updates
GMAIL_PUBSUB_PULL_SUBSCRIPTION=projects/<project-id>/subscriptions/clira-gmail-pull-sub
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./.clira-runtime/google-service-account.json

# AI provider
AI_PROVIDER=google
# Required when AI_PROVIDER=google.
GOOGLE_GENERATIVE_AI_API_KEY=
# Alias supported by the runtime for Gemini.
GOOGLE_API_KEY=
# Required when AI_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# ===== SELF-HOST OPTIONALS =====

# Public landing page used for unauthenticated redirects. Leave blank to use /signin.
APP_LANDING_PAGE_URL=

# Gmail pull worker runtime tuning
GMAIL_PUBSUB_PULL_MAX_MESSAGES=25
GMAIL_PUBSUB_PULL_MAX_BYTES=10485760
GMAIL_PUBSUB_PULL_SHUTDOWN_TIMEOUT_MS=15000

# OpenAI-compatible transport. These env names remain for compatibility, but the base URL
# may point at OpenRouter, LM Studio, vLLM, or another OpenAI-compatible endpoint.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=
OPENROUTER_SUPPORTS_STRUCTURED_OUTPUTS=

# Optional integrations. Leave blank to disable the related feature.
TELEGRAM_BOT_TOKEN=
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_TIMEOUT_MS=10000
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_TIMEOUT_MS=12000

# ===== ADVANCED RUNTIME AND MODEL OVERRIDES =====

NODE_ENV=development
LOG_LEVEL=info
CLIRA_AI_TRACE_ENABLED=true
CLIRA_AI_TRACE_DIR=.clira-runtime/ai-traces
CLIRA_AI_TRACE_CAPTURE=full

TELEGRAM_ENABLED=true
TELEGRAM_POLL_RETRY_MAX_MS=30000
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# Local cron runner defaults. Docker overrides CRON_TARGET_BASE_URL to use the internal app service.
CRON_TARGET_BASE_URL=http://localhost:3000
CRON_TIMEZONE=UTC
CRON_REMINDERS_SCHEDULE=* * * * *
CRON_SORT_SCHEDULE=0 */2 * * *
CRON_RENEW_GMAIL_WATCHES_SCHEDULE=0 6 * * *

NEXT_PUBLIC_SUPPORT_EMAIL=support@clira.dev
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_CLIRA_TEXT_NUMBER=
NEXT_PUBLIC_WHATSAPP_CTA_URL=

FEATURE_FLAG_GMAIL_DRAFTS=true
INBOX_RETRIEVAL_V2_ENABLED=true
INBOX_VECTOR_ENABLED=true
INBOX_LLM_RERANK_DEEP_ONLY=true

FLASH_MODEL=
FLASH_MODEL_PROVIDER=
PRO_MODEL=
PRO_MODEL_PROVIDER=
FLASH_LITE_MODEL=
FLASH_LITE_MODEL_PROVIDER=
FOLDER_GENERATION_MODEL=
FOLDER_GENERATION_MODEL_PROVIDER=
EXEC_AGENT_MODEL=
EXEC_AGENT_MODEL_PROVIDER=
EMAIL_RETRIEVAL_MODEL=
EMAIL_RETRIEVAL_MODEL_PROVIDER=
CALENDAR_SEARCH_MODEL=
CALENDAR_SEARCH_MODEL_PROVIDER=
REPLY_ROUTER_MODEL=
REPLY_ROUTER_MODEL_PROVIDER=
