# ===== REQUIRED (Core App) =====

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/clira

# Redis
REDIS_URL=redis://localhost:16379

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail Ingestion (pull default, push optional)
GMAIL_INGESTION_MODE=pull
GMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/clira-email-updates
GMAIL_PUBSUB_PULL_SUBSCRIPTION=projects/<project-id>/subscriptions/clira-gmail-pull-sub
GMAIL_PUBSUB_PULL_MAX_MESSAGES=25
GMAIL_PUBSUB_PULL_MAX_BYTES=10485760
GMAIL_PUBSUB_PULL_SHUTDOWN_TIMEOUT_MS=15000
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# LLM Provider (default)
GOOGLE_GENERATIVE_AI_API_KEY=

# Telegram Bot API (required only if Telegram channel is used)
TELEGRAM_BOT_TOKEN=

# Long-term memory (required for memory features)
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_TIMEOUT_MS=10000

# ===== OPTIONAL (Runtime + Public Config + Feature Flags) =====

# Runtime tuning
NODE_ENV=development
LOG_LEVEL=info

# Telegram runtime tuning
TELEGRAM_ENABLED=true
TELEGRAM_POLL_RETRY_MAX_MS=30000
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# Local cron runner (used by npm run start:cron and docker cron service)
CRON_TARGET_BASE_URL=http://localhost:3000
CRON_TIMEZONE=UTC
CRON_REMINDERS_SCHEDULE=* * * * *
CRON_SORT_SCHEDULE=0 */2 * * *
CRON_RENEW_GMAIL_WATCHES_SCHEDULE=0 6 * * *

# Public contact + CTA configuration (safe to expose)
NEXT_PUBLIC_SUPPORT_EMAIL=support@clira.dev
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_CLIRA_TEXT_NUMBER=
NEXT_PUBLIC_WHATSAPP_CTA_URL=

# Feature flags
FEATURE_FLAG_GMAIL_DRAFTS=true
INBOX_RETRIEVAL_V2_ENABLED=true
INBOX_VECTOR_ENABLED=true
INBOX_LLM_RERANK_DEEP_ONLY=true

# Executive selector routing (experimental)
EA_SELECTOR_CEREBRAS_ENABLED=false
EA_SELECTOR_CEREBRAS_MODEL=llama3.1-8b
EA_SELECTOR_LLM_MIN_CONFIDENCE=0.55

# Optional per-channel overrides for selector routing (true/false)
EA_SELECTOR_CEREBRAS_TELEGRAM=
EA_SELECTOR_CEREBRAS_WHATSAPP=
EA_SELECTOR_CEREBRAS_TWILIO=

# Required only when EA_SELECTOR_CEREBRAS_ENABLED=true
CEREBRAS_API_KEY=
