    "@tsparticles/slim": "^3.8.1",
    "@types/node-cron": "^3.0.11",
    "ai": "^6.0.44",
    "bullmq": "^5.33.5",
    "chrono-node": "^2.7.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
    "fasttext.wasm": "^1.0.1",
    "file-type": "^16.5.4",
    "framer-motion": "^12.22.0",
    "googleapis": "^149.0.0",
    "grammy": "^1.40.0",
