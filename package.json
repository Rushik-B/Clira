{
  "name": "clira-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsc -p config/tsconfig.worker.json && tsc-alias -p config/tsconfig.worker.json",
    "build:worker": "tsc -p config/tsconfig.worker.json && tsc-alias -p config/tsconfig.worker.json",
    "prebuild": "npm run prisma:generate",
    "prebuild:worker": "npm run prisma:generate",
    "dev:worker:watch": "npx nodemon --watch src --ext ts --ignore src/app --ignore src/components --ignore src/hooks --ignore src/lib/mocks --exec \"npm run build:worker\"",
    "start": "node server.js",
    "start:worker": "node dist/worker.js",
    "start:backfill-worker": "node dist/backfill-worker.js",
    "start:gmail-pull-worker": "node dist/gmail-pull-worker.js",
    "start:cron": "node dist/cron.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "postinstall": "npm run prisma:generate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "setup:google": "bash scripts/setup-google.sh",
    "benchmark": "bash scripts/benchmark.sh",
    "remotion:preview": "remotion studio",
    "remotion:render": "remotion render LaunchVideo out/launch-video.mp4"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.32",
    "@ai-sdk/react": "^3.0.46",
    "@auth/prisma-adapter": "^2.4.1",
    "@aws-sdk/client-kms": "^3.893.0",
    "@aws-sdk/client-s3": "^3.845.0",
    "@aws-sdk/lib-storage": "^3.845.0",
    "@google-cloud/pubsub": "^5.3.0",
    "@google/generative-ai": "^0.21.0",
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
