    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tmp": "^0.2.3",
    "twilio": "^5.11.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@remotion/cli": "^4.0.409",
    "@remotion/google-fonts": "^4.0.409",
    "@tailwindcss/postcss": "^4",
    "@types/dotenv": "^6.1.1",
