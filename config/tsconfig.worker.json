{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "../dist",
    "rootDir": "../src",
    "baseUrl": "..",
    "declaration": false,
    "sourceMap": false,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "../src/backfill-worker.ts",
    "../src/cron.ts",
    "../src/worker.ts",
    "../src/lib/**/*",
    "../src/types/**/*"
  ],
  "exclude": [
    "../src/app/**/*",
    "../src/components/**/*",
    "../src/hooks/**/*",
    "../src/lib/auth/auth-utils.ts",
    "../src/lib/mocks/**/*",
    "../node_modules"
  ]
} 
